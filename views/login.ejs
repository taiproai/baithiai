<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - FPT Poly Đà Nẵng</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --fpt-orange: #F26F21; }
        .bg-fpt { background-color: var(--fpt-orange); }
        .text-fpt { color: var(--fpt-orange); }
    </style>
</head>
<body class="h-screen flex relative overflow-hidden bg-gray-900" style="background-image: url('https://s3-han02.fptcloud.com/fpl-ap/silde-ap/hero1.JPG'); background-size: cover; background-position: center;">
    
    <!-- Lớp phủ tối để làm nổi bật Form Đăng nhập -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm z-0"></div>

    <div class="m-auto w-full max-w-md p-6 relative z-10">
        <div class="bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-2xl border-t-4 border-fpt">
            <div class="flex justify-center mb-8">
                <div class="bg-fpt text-white font-bold px-5 py-2.5 rounded-xl text-2xl shadow-lg transform -translate-y-4 shadow-orange-500/40">
                    FPT Polytechnic
                </div>
            </div>
            
            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-gray-800">Quản lý Thiết bị</h2>
                <p class="text-sm text-gray-500 mt-2">Đăng nhập để vào không gian làm việc</p>
            </div>
            
            <div class="space-y-5">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-orange-400">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <input type="text" id="username" placeholder="Tên đăng nhập (admin / nhanvien)" class="w-full pl-11 p-3.5 bg-orange-50/50 border border-orange-200 rounded-xl focus:ring-2 focus:ring-orange-400 focus:bg-white outline-none transition text-gray-700">
                </div>
                
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-orange-400">
                        <i class="fa-solid fa-lock"></i>
                    </div>
                    <input type="password" id="password" placeholder="Mật khẩu (123456)" class="w-full pl-11 p-3.5 bg-orange-50/50 border border-orange-200 rounded-xl focus:ring-2 focus:ring-orange-400 focus:bg-white outline-none transition text-gray-700">
                </div>

                <button onclick="login()" class="w-full bg-fpt text-white p-4 rounded-xl font-bold text-lg shadow-lg shadow-orange-500/40 hover:bg-orange-600 hover:-translate-y-0.5 transition-all flex justify-center items-center gap-2 mt-4">
                    Đăng nhập <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>

            <div id="loginErr" class="mt-5 p-3 bg-red-50 text-red-600 rounded-xl text-sm text-center font-medium hidden border border-red-100 items-center justify-center gap-2">
                <i class="fa-solid fa-circle-exclamation"></i> <span></span>
            </div>
        </div>
        <p class="text-center text-white/70 text-sm mt-8 relative z-10 font-medium tracking-wide shadow-black">© 2026 FPT Polytechnic Đà Nẵng</p>
    </div>

    <script>
        if (localStorage.getItem('currentUser')) window.location.href = '/';

        function login() {
            const u = document.getElementById('username').value;
            const p = document.getElementById('password').value;
            fetch('/api/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username: u, password: p })
            }).then(r => r.json()).then(res => {
                if(res.success) { localStorage.setItem('currentUser', JSON.stringify(res.user)); window.location.href = '/'; } 
                else {
                    const errBox = document.getElementById('loginErr');
                    errBox.querySelector('span').innerText = res.message;
                    errBox.classList.remove('hidden'); errBox.classList.add('flex');
                }
            });
        }
        document.getElementById('password').addEventListener('keypress', e => { if (e.key === 'Enter') login(); });
    </script>
</body>
</html>