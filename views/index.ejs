                    }
                }
                if (item.status === 'Hỏng' || item.status === 'Bảo trì') {
                    if (currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'tech' || item.current_borrower === currentUser.username) { 
                        actionHTML += `<button onclick="openChat('${item.qa_code}', 'general')" class="w-full md:w-auto bg-blue-50 text-blue-600 border border-blue-200 px-3 py-1.5 rounded-md hover:bg-blue-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1 md:mt-0 md:mr-1" title="Ticket hỏi thông tin sự cố"><i class="fa-solid fa-comments"></i> Ticket Sự Cố</button>`; 
                    }
                    if (currentUser.role === 'admin' || currentUser.role === 'tech') {
                        actionHTML += `<button onclick="openChat('${item.qa_code}', 'tech')" class="w-full md:w-auto bg-purple-50 text-purple-600 border border-purple-200 px-3 py-1.5 rounded-md hover:bg-purple-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1 md:mt-0 md:mr-1" title="Kênh Kỹ thuật trao đổi riêng với Admin"><i class="fa-solid fa-user-shield"></i> Chat Nội bộ IT</button>`;
                    }

                    if(currentUser.role === 'admin') {
                        if (item.status === 'Hỏng') { actionHTML += `<button onclick="markAsFixing('${item.qa_code}')" class="w-full md:w-auto bg-orange-50 text-orange-600 border border-orange-200 px-3 py-1.5 rounded-md hover:bg-orange-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1"><i class="fa-solid fa-tools"></i> Đang sửa</button>`; }
                        actionHTML += `<button onclick="markAsFixed('${item.qa_code}')" class="w-full md:w-auto bg-indigo-50 text-indigo-600 border border-indigo-200 px-3 py-1.5 rounded-md hover:bg-indigo-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1 md:ml-1"><i class="fa-solid fa-check-double"></i> Đã xong</button>`;
                    } else if (currentUser.role === 'tech') {
                        if (item.status === 'Hỏng') { actionHTML += `<button onclick="markAsFixing('${item.qa_code}')" class="w-full md:w-auto bg-orange-50 text-orange-600 border border-orange-200 px-3 py-1.5 rounded-md hover:bg-orange-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1"><i class="fa-solid fa-tools"></i> Tiếp nhận sửa</button>`; } 
                        else if (item.status === 'Bảo trì') { actionHTML += `<button onclick="reportFixed('${item.qa_code}')" class="w-full md:w-auto bg-emerald-50 text-emerald-600 border border-emerald-200 px-3 py-1.5 rounded-md hover:bg-emerald-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1"><i class="fa-solid fa-flag-checkered"></i> Báo cáo Xong</button>`; }
                    } else { actionHTML += `<span class="text-xs text-red-500 font-semibold flex items-center justify-center mt-2 border border-red-200 bg-red-50 py-1.5 rounded-md w-full md:w-auto px-2"><i class="fa-solid fa-ban mr-1"></i> ${item.status === 'Hỏng' ? 'Chờ xử lý' : 'Đang sửa chữa'}</span>`; }
                }

                let adminHTML = `<button onclick="showAssetDetails('${item.qa_code}')" class="flex-1 md:flex-none text-gray-500 hover:text-fpt bg-orange-50 md:bg-transparent py-1.5 rounded transition" title="Chi tiết"><i class="fa-solid fa-circle-info"></i></button>`;
                if(currentUser.role === 'admin' || currentUser.role === 'manager') {
                    adminHTML += `<button onclick="openEdit('${item.qa_code}')" class="flex-1 md:flex-none text-blue-500 hover:text-blue-700 bg-blue-50 md:bg-transparent py-1.5 rounded transition" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></button>`;
                    adminHTML += `<button onclick="deleteAsset('${item.qa_code}')" class="flex-1 md:flex-none text-red-500 hover:text-red-700 bg-red-50 md:bg-transparent py-1.5 rounded transition" title="Xóa"><i class="fa-solid fa-trash"></i></button>`;
                }
                tbody.innerHTML += `<tr class="flex flex-col md:table-row bg-white md:bg-transparent rounded-2xl border border-orange-100 md:border-b hover:bg-orange-50/80 transition"><td class="p-3 md:p-4 flex md:table-cell justify-between items-center border-b border-dashed border-orange-100 md:border-none"><span class="md:hidden text-xs font-bold text-gray-400 uppercase">Mã QA</span><span class="font-mono font-bold">${item.qa_code}</span></td><td class="p-3 md:p-4 flex md:table-cell justify-between items-center border-b border-dashed border-orange-100 md:border-none"><span class="md:hidden text-xs font-bold text-gray-400 uppercase">Tên</span><span class="font-medium">${item.name}</span></td><td class="p-3 md:p-4 flex md:table-cell justify-between items-center border-b border-dashed border-orange-100 md:border-none"><span class="md:hidden text-xs font-bold text-gray-400 uppercase">Loại/Phòng</span><div class="text-right md:text-left text-gray-500">${item.type} <br class="hidden md:block"><span class="text-xs text-orange-500 font-medium"><i class="fa-solid fa-location-dot"></i> ${item.room}</span></div></td><td class="p-3 md:p-4 flex md:table-cell justify-between items-center border-b border-dashed border-orange-100 md:border-none"><span class="md:hidden text-xs font-bold text-gray-400 uppercase">Trạng thái</span><div class="text-right md:text-left"><span class="${statusColor}">${displayStatus}</span>${borrowerInfo}</div></td><td class="p-3 md:p-4 flex flex-col md:table-cell border-b border-dashed border-orange-100 md:border-none gap-2"><span class="md:hidden text-xs font-bold text-gray-400 uppercase mb-1">Thao tác</span><div class="flex flex-col md:flex-row gap-2 justify-end md:justify-center w-full">${actionHTML}</div></td><td class="p-3 md:p-4 flex flex-col md:table-cell gap-2 bg-orange-50/50 md:bg-transparent rounded-b-2xl md:rounded-none"><span class="md:hidden text-xs font-bold text-gray-400 uppercase mb-1">Quản lý</span><div class="flex gap-2 justify-between md:justify-center w-full">${adminHTML}</div></td></tr>`;
            });
        }

        function loadMaintenance() {
            if(currentUser.role !== 'admin' && currentUser.role !== 'manager' && currentUser.role !== 'tech') return;
            fetch('/api/maintenance').then(r => r.json()).then(data => {
                const tbody = document.getElementById('maintenanceTableBody'); tbody.innerHTML = '';
                if(data.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-gray-500 font-medium">Không có yêu cầu bảo trì nào.</td></tr>'; return; }
                data.forEach(item => {
                    let badge = item.status === 'Hỏng' ? '<span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-lg text-xs font-bold">Chờ xử lý</span>' : '<span class="bg-blue-100 text-blue-700 px-2 py-1 rounded-lg text-xs font-bold">Đang sửa chữa</span>';
                    
                    let actions = `<button onclick="openChat('${item.qa_code}', 'general')" class="text-blue-500 hover:text-white bg-blue-50 hover:bg-blue-500 px-2 py-1.5 rounded transition mr-1" title="Ticket Sự Cố (Chat với người báo hỏng)"><i class="fa-solid fa-comments"></i></button>`;
                    if (currentUser.role === 'tech' || currentUser.role === 'admin') { 
                        actions += `<button onclick="openChat('${item.qa_code}', 'tech')" class="text-purple-500 hover:text-white bg-purple-50 hover:bg-purple-500 px-2 py-1.5 rounded transition mr-1" title="Chat Nội bộ (Chỉ Admin & Kỹ thuật)"><i class="fa-solid fa-user-shield"></i></button>`; 
                    }

                    if (currentUser.role === 'tech') {
                        if (item.status === 'Hỏng') { actions += `<button onclick="markAsFixing('${item.qa_code}')" class="text-orange-500 hover:text-white bg-orange-50 hover:bg-orange-500 px-2 py-1.5 rounded transition mr-1" title="Tiếp nhận sửa"><i class="fa-solid fa-tools"></i> Tiếp nhận</button>`; } 
                        else if (item.status === 'Bảo trì') { actions += `<button onclick="reportFixed('${item.qa_code}')" class="text-emerald-500 hover:text-white bg-emerald-50 hover:bg-emerald-500 px-2 py-1.5 rounded transition" title="Báo cáo Xong"><i class="fa-solid fa-flag-checkered"></i> Báo cáo Xong</button>`; }
                    } else if (currentUser.role === 'admin') {
                        if (item.status === 'Hỏng') { actions += `<button onclick="markAsFixing('${item.qa_code}')" class="text-orange-500 hover:text-white bg-orange-50 hover:bg-orange-500 px-2 py-1.5 rounded transition mr-1" title="Đang sửa"><i class="fa-solid fa-screwdriver-wrench"></i></button>`; }
                        actions += `<button onclick="markAsFixed('${item.qa_code}')" class="text-emerald-500 hover:text-white bg-emerald-50 hover:bg-emerald-500 px-2 py-1.5 rounded transition" title="Xác nhận Xong"><i class="fa-solid fa-check-double"></i> Duyệt Xong</button>`;
                    } else { actions += `<span class="text-xs text-red-500 font-semibold px-2 py-1 bg-red-50 rounded border border-red-200 ml-1">Đang theo dõi</span>`; }
                    let timeStr = item.report_time ? new Date(item.report_time).toLocaleString('vi-VN', {hour:'2-digit', minute:'2-digit', day:'2-digit', month:'2-digit', year:'numeric'}) : '-';
                    tbody.innerHTML += `<tr class="hover:bg-emerald-50/50 transition"><td class="p-4 border-b border-dashed border-emerald-100"><div class="font-bold text-emerald-600">${item.name}</div><div class="font-mono text-xs text-gray-500">${item.qa_code}</div></td><td class="p-4 border-b border-dashed border-emerald-100"><div class="font-medium text-gray-800">${item.reporter || '-'}</div><div class="text-[10px] text-gray-400 mt-1"><i class="fa-regular fa-calendar"></i> ${timeStr}</div></td><td class="p-4 border-b border-dashed border-emerald-100 text-sm text-gray-600 max-w-xs truncate" title="${item.error_note}">${item.error_note || '-'}</td><td class="p-4 border-b border-dashed border-emerald-100">${badge}</td><td class="p-4 border-b border-dashed border-emerald-100 text-center">${actions}</td></tr>`;
                });
            });
        }
        function reportFixed(qa_code) {
            if(confirm('Bạn xác nhận đã sửa xong và muốn báo cáo với Admin để duyệt?')) {
                socket.emit("sendMessage", { qa_code: qa_code + '_tech', sender: 'Hệ thống', role: 'system', message: `[Hệ thống] Nhân viên Kỹ thuật (${currentUser.username}) báo cáo đã khắc phục xong sự cố thiết bị. Yêu cầu Admin kiểm tra và xác nhận "Duyệt Xong" để thiết bị trở lại hoạt động.` });
                alert('Đã gửi báo cáo cho Admin trong kênh Chat Kỹ thuật!');
            }
        }

        function toggleNotif() { document.getElementById('notifDropdown').classList.toggle('hidden'); document.getElementById('notifBadge').innerText = '0'; document.getElementById('notifBadge').classList.add('hidden'); }
        
        function startScanner() { 
            const readerDiv = document.getElementById('reader'); readerDiv.classList.remove('hidden'); 
            if(!html5QrcodeScanner) { 
                html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: {width: 250, height: 250} }, false); 
                html5QrcodeScanner.render((text) => { 
                    document.getElementById('scanCode').value = text; html5QrcodeScanner.clear(); readerDiv.classList.add('hidden'); html5QrcodeScanner = null; 
                    const foundAsset = allAssets.find(a => a.qa_code === text); if (foundAsset) showAssetDetails(text); else filterAssets(); 
                }, () => {}); 
            } 
        }
        function scanImage(event) { 
            if (event.target.files.length == 0) return; 
            new Html5Qrcode("reader").scanFile(event.target.files[0], true).then(text => { 
                document.getElementById('scanCode').value = text; 
                const foundAsset = allAssets.find(a => a.qa_code === text); if (foundAsset) showAssetDetails(text); else filterAssets(); 
            }).catch(err => alert('Không đọc được mã QR!')); event.target.value = ''; 
        }
        
        function filterAssets() { 
            const term = document.getElementById('scanCode').value.toLowerCase(); 
            const categoryFilterEl = document.getElementById('assetCategoryFilter');
            const cat = categoryFilterEl ? categoryFilterEl.value : 'all';
            
            renderTable(allAssets.filter(item => {
                const matchTerm = item.qa_code.toLowerCase().includes(term) || item.name.toLowerCase().includes(term);
                const matchCat = cat === 'all' || item.type === cat;
                return matchTerm && matchCat;
            })); 
        }
        
        function showAssetDetails(qa_code) { const item = allAssets.find(a => a.qa_code === qa_code); if(!item) return; document.getElementById('detQa').innerText = item.qa_code; document.getElementById('detName').innerText = item.name; document.getElementById('detTypeRoom').innerText = `${item.type} - ${item.room}`; let statusHtml = `<span class="font-bold ${item.status === 'Sẵn sàng' ? 'text-emerald-600' : (item.status === 'Đang sử dụng' ? 'text-blue-600' : 'text-red-600')}">${item.status}</span>`; if (item.status === 'Đang sử dụng' && item.current_borrower) statusHtml += ` <span class="text-gray-500 font-normal">(Mượn: ${item.current_borrower})</span>`; document.getElementById('detStatus').innerHTML = statusHtml; document.getElementById('detNote').innerText = item.borrow_note || "Chưa có ghi chú"; document.getElementById('detQRCode').innerHTML = ''; new QRCode(document.getElementById('detQRCode'), { text: qa_code, width: 140, height: 140, colorDark : "#F26F21", colorLight : "#ffffff" }); document.getElementById('detQRCode').setAttribute('data-qa', qa_code); document.getElementById('detailModal').classList.remove('hidden'); }
        function downloadQR() { const qrImg = document.querySelector('#detQRCode img'); if (!qrImg) return; const qa_code = document.getElementById('detQRCode').getAttribute('data-qa'); const a = document.createElement('a'); a.href = qrImg.src; a.download = `QR_${qa_code}.png`; a.click(); }
        function printQR() { const qrImg = document.querySelector('#detQRCode img'); if (!qrImg) return; const qa_code = document.getElementById('detQRCode').getAttribute('data-qa'); const win = window.open(''); win.document.write(`<html><body style="text-align:center; padding: 40px; font-family: sans-serif;"><h2 style="color: #F26F21; font-size: 24px; margin-bottom: 10px;">${qa_code}</h2><img src="${qrImg.src}" style="width:200px; height:200px; border: 1px solid #ccc; padding: 10px; border-radius: 10px;"/><script>setTimeout(() => { window.print(); window.close(); }, 500);<\/script></body></html>`); }
        
        function loadAssets() { fetch('/api/assets').then(r => r.json()).then(data => { allAssets = data; loadAssetCategories(); filterAssets(); updateNotificationsUI(); loadMaintenance(); }); }
        
        function loadAssetCategories() {
            fetch('/api/categories').then(r => r.json()).then(cats => {
                let options = '<option value="all">Tất cả danh mục</option>';
                cats.forEach(c => options += `<option value="${c}">${c}</option>`);
                const filterEl = document.getElementById('assetCategoryFilter');
                if(filterEl) filterEl.innerHTML = options;
            });
        }
        
        function loadUsers() { 
            fetch(`/api/users?requester_id=${currentUser.id}&requester_role=${currentUser.role}`).then(r => r.json()).then(data => { 
                const tbody = document.getElementById('userTableBody'); if(!tbody) return; tbody.innerHTML = ''; 
                data.forEach(user => { 
                    let roleBadge = '<span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs">Nhân viên</span>'; 
                    if(user.role === 'admin') roleBadge = '<span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs">Admin</span>'; 
                    if(user.role === 'manager') roleBadge = '<span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full text-xs">Tổ trưởng</span>'; 
                    if(user.role === 'tech') roleBadge = '<span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs">Kỹ thuật</span>'; 
                    
                    let actionBtns = '';
                    if(currentUser.role === 'admin') {
                        actionBtns += `<button onclick="openEditUser(${user.id}, '${user.username}', '${user.role}', '${user.department || ''}')" class="text-blue-500 hover:text-white bg-blue-50 hover:bg-blue-500 px-3 py-1.5 rounded mr-1" title="Cập nhật Quyền"><i class="fa-solid fa-pen"></i></button>`;
                    }
                    actionBtns += `<button onclick="deleteUser(${user.id})" class="text-red-500 hover:text-white bg-red-50 hover:bg-red-500 px-3 py-1.5 rounded" title="Xóa Tài khoản"><i class="fa-solid fa-trash"></i></button>`;
                    
                    tbody.innerHTML += `<tr><td class="p-4 border-b border-orange-100">${user.id}</td><td class="p-4 border-b border-orange-100 font-bold text-gray-700">${user.username}</td><td class="p-4 border-b border-orange-100">${roleBadge}</td><td class="p-4 border-b border-orange-100">${user.department || '-'}</td><td class="p-4 border-b border-orange-100 text-center whitespace-nowrap">${actionBtns}</td></tr>`; 
                }); 
            }).catch(e => console.log(e)); 
        }
        function logout() { localStorage.removeItem('currentUser'); window.location.href = '/login'; }

        function openActionModal(qa_code, action_type) {
            document.getElementById('actionQaCode').value = qa_code; document.getElementById('actionType').value = action_type; document.getElementById('actionNote').value = ''; document.getElementById('actionNewRoom').value = '';
            const titleEl = document.getElementById('actionModalTitle'); const descEl = document.getElementById('actionModalDesc'); const btnEl = document.getElementById('btnSubmitAction'); const roomInput = document.getElementById('actionNewRoom'); const dateContainer = document.getElementById('expectedReturnContainer');
            if(action_type === 'Mượn' || action_type === 'Đăng ký mượn') {
                titleEl.innerText = action_type === 'Mượn' ? 'Mượn thiết bị' : 'Đăng ký mượn'; descEl.innerText = `Mã QA: ${qa_code}. Vui lòng nhập ghi chú.`;
                btnEl.className = 'w-full bg-blue-500 text-white p-3 rounded-xl font-bold shadow-md'; roomInput.classList.remove('hidden'); dateContainer.classList.remove('hidden');
                let defaultDate = new Date(); defaultDate.setDate(defaultDate.getDate() + 3); document.getElementById('actionExpectedReturn').value = (new Date(defaultDate - (defaultDate.getTimezoneOffset() * 60000))).toISOString().slice(0, 16);
            } else if (action_type === 'Trả') {
                titleEl.innerText = 'Trả thiết bị'; descEl.innerText = `Xác nhận trả ${qa_code}?`;
                btnEl.className = 'w-full bg-emerald-500 text-white p-3 rounded-xl font-bold shadow-md'; roomInput.classList.add('hidden'); dateContainer.classList.add('hidden');
            } else {
                titleEl.innerText = 'Báo lỗi'; descEl.innerText = `Xác nhận báo lỗi ${qa_code}?`;
                btnEl.className = 'w-full bg-red-500 text-white p-3 rounded-xl font-bold shadow-md'; roomInput.classList.add('hidden'); dateContainer.classList.add('hidden');
            }
            document.getElementById('actionModal').classList.remove('hidden');
        }

        function submitAction() {
            const data = { qa_code: document.getElementById('actionQaCode').value, username: currentUser.username, role: currentUser.role, action_type: document.getElementById('actionType').value, note: document.getElementById('actionNote').value, new_room: document.getElementById('actionNewRoom').value, expected_return: document.getElementById('actionExpectedReturn').value };
            if((data.action_type === 'Mượn' || data.action_type === 'Đăng ký mượn') && data.note.trim() === '') return alert('Vui lòng nhập ghi chú!');
            fetch('/api/action', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()).then(res => { if(res.success) { document.getElementById('actionModal').classList.add('hidden'); loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.message); });
        }

        function approveRequest(qa_code, decision) { if(confirm(`Xác nhận Duyệt / Từ chối?`)) { fetch('/api/approve', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ qa_code, admin_username: currentUser.username, decision }) }).then(r => r.json()).then(res => { if(res.success) { loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.message); }); } }
        function markAsFixing(qa_code) { if(confirm(`Xác nhận đang sửa thiết bị này?`)) { const item = allAssets.find(a=>a.qa_code===qa_code); fetch(`/api/assets/${qa_code}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: item.name, type: item.type, room: item.room, status: 'Bảo trì' }) }).then(r => r.json()).then(res => { if(res.success) { loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.error); }); } }
        function markAsFixed(qa_code) { if(confirm(`Xác nhận duyệt thiết bị đã sửa xong và cho phép tiếp tục hoạt động?`)) { fetch(`/api/assets/${qa_code}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: allAssets.find(a=>a.qa_code===qa_code).name, type: allAssets.find(a=>a.qa_code===qa_code).type, room: allAssets.find(a=>a.qa_code===qa_code).room, status: 'Sẵn sàng' }) }).then(r => r.json()).then(res => { if(res.success) { loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.error); }); } }

        function loadDashboard() {
            fetch('/api/dashboard?role=' + currentUser.role).then(r => r.json()).then(data => {
                document.getElementById('dashTotal').innerText = data.total || 0; document.getElementById('dashInUse').innerText = data.in_use || 0; document.getElementById('dashBroken').innerText = data.broken || 0;
                renderChart(data.in_use || 0, data.broken || 0, data.total || 0);
            });
            fetch('/api/history?role=' + currentUser.role).then(r => r.json()).then(data => {
                historyData = data;
                filterStats(); 
            });
        }

        function filterStats() {
            let filteredHistory = historyData.filter(h => h.action_type === 'Mượn');
            const assetCounts = {};
            const userCounts = {};
            filteredHistory.forEach(h => {
                assetCounts[h.qa_code] = (assetCounts[h.qa_code] || 0) + 1;
                userCounts[h.username] = (userCounts[h.username] || 0) + 1;
            });
            const topAssets = Object.keys(assetCounts).map(k => ({ code: k, count: assetCounts[k] })).sort((a,b) => b.count - a.count).slice(0, 5);
            const topUsers = Object.keys(userCounts).map(k => ({ user: k, count: userCounts[k] })).sort((a,b) => b.count - a.count).slice(0, 5);
            
            const aList = document.getElementById('topAssetsList');
            if (topAssets.length === 0) {
                aList.innerHTML = '<div class="text-center text-gray-400 text-sm py-4 italic">Chưa có dữ liệu mượn phù hợp.</div>';
            } else {
                aList.innerHTML = '';
                topAssets.forEach(a => {
                    const info = allAssets.find(x => x.qa_code === a.code);
                    const displayName = info ? info.name : a.code;
                    aList.innerHTML += `
                        <div class="flex justify-between items-center bg-orange-50 hover:bg-orange-100 transition p-3 rounded-xl border border-orange-100">
                            <div class="font-medium text-sm text-gray-800">${displayName} <br><span class="text-xs text-gray-500 font-mono">${a.code}</span></div>
                            <div class="bg-white text-orange-600 border border-orange-200 font-bold px-3 py-1.5 rounded-full text-xs shadow-sm">${a.count} lần</div>
                        </div>`;
                });
            }

            const uList = document.getElementById('topUsersList');
            if (topUsers.length === 0) {
                uList.innerHTML = '<div class="text-center text-gray-400 text-sm py-4 italic">Chưa có dữ liệu người mượn.</div>';
            } else {
                uList.innerHTML = '';
                topUsers.forEach(u => {
                    uList.innerHTML += `
                        <div class="flex justify-between items-center bg-blue-50 hover:bg-blue-100 transition p-3 rounded-xl border border-blue-100">
                            <div class="font-bold text-sm text-gray-800"><i class="fa-solid fa-circle-user text-blue-400 text-lg mr-2 align-middle"></i>${u.user}</div>
                            <div class="bg-white text-blue-600 border border-blue-200 font-bold px-3 py-1.5 rounded-full text-xs shadow-sm">${u.count} lần mượn</div>
                        </div>`;
                });
            }
        }
        
        function renderChart(inUse, broken, total) {
            const available = total - inUse - broken; const ctx = document.getElementById('statusChart').getContext('2d');
            if(statusChartInstance) statusChartInstance.destroy();
            statusChartInstance = new Chart(ctx, { type: 'doughnut', data: { labels: ['Sẵn sàng', 'Đang sử dụng', 'Hỏng/Bảo trì'], datasets: [{ data: [available, inUse, broken], backgroundColor: ['#10b981', '#3b82f6', '#ef4444'], borderWidth: 0 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: {size: 10} } } } } });
        }

        function exportHistoryExcel() { 
            if(currentUser.role !== 'admin') return alert('Chỉ Admin mới có quyền trích xuất dữ liệu!');
            fetch('/api/history?role=' + currentUser.role).then(res => res.json()).then(data => {
                if(!data || data.length === 0) return alert('Không có dữ liệu giao dịch trong 30 ngày qua!');
                const excelData = data.map(item => ({ "ID Lịch sử": item.id, "Ngày thực hiện": new Date(item.timestamp).toLocaleString('vi-VN'), "Mã QA": item.qa_code, "Người thực hiện": item.username, "Thao tác": item.action_type, "Ghi chú / Lý do lỗi": item.note || 'Không có', "Hạn trả dự kiến": item.expected_return ? new Date(item.expected_return).toLocaleString('vi-VN') : 'N/A' }));
                const worksheet = XLSX.utils.json_to_sheet(excelData); const wscols = [ {wch:10}, {wch:20}, {wch:15}, {wch:15}, {wch:15}, {wch:35}, {wch:20} ]; worksheet['!cols'] = wscols; const workbook = XLSX.utils.book_new(); XLSX.utils.book_append_sheet(workbook, worksheet, "LichSu_30Ngay"); XLSX.writeFile(workbook, `Lich_Su_Thiet_Bi_${new Date().toISOString().split('T')[0]}.xlsx`);
            }).catch(err => { console.error(err); alert('Lỗi trong quá trình trích xuất Excel!'); });
        }

        // HÀM XUẤT PDF LỊCH SỬ DẠNG BẢNG (Giống Excel)
        function exportPDF() { 
            if(currentUser.role !== 'admin') return alert('Chỉ Admin mới có quyền trích xuất dữ liệu!');
            
            fetch('/api/history?role=' + currentUser.role).then(res => res.json()).then(data => {
                if(!data || data.length === 0) return alert('Không có dữ liệu giao dịch trong 30 ngày qua!');

                // Tạo một bảng HTML ảo (ẩn) để cấu trúc dữ liệu PDF
                const tempContainer = document.createElement('div');
                tempContainer.style.padding = '20px';
                tempContainer.style.fontFamily = 'sans-serif';
                tempContainer.style.color = '#333';

                let html = `
                    <h2 style="text-align: center; color: #F26F21; margin-bottom: 20px; font-size: 18px;">LỊCH SỬ GIAO DỊCH THIẾT BỊ (30 NGÀY)</h2>
                    <p style="text-align: right; font-size: 12px; margin-bottom: 10px;">Ngày xuất: ${new Date().toLocaleDateString('vi-VN')}</p>
                    <table style="width: 100%; border-collapse: collapse; font-size: 10px; text-align: left;">
                        <thead>
                            <tr style="background-color: #f97316; color: white;">
                                <th style="border: 1px solid #ddd; padding: 8px;">ID</th>
                                <th style="border: 1px solid #ddd; padding: 8px;">Ngày TH</th>
                                <th style="border: 1px solid #ddd; padding: 8px;">Mã QA</th>
                                <th style="border: 1px solid #ddd; padding: 8px;">Người TH</th>
                                <th style="border: 1px solid #ddd; padding: 8px;">Thao tác</th>
                                <th style="border: 1px solid #ddd; padding: 8px;">Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                `;

                data.forEach((item, index) => {
                    const bg = index % 2 === 0 ? '#fff' : '#fff7ed';
                    html += `
                        <tr style="background-color: ${bg};">
                            <td style="border: 1px solid #ddd; padding: 8px;">${item.id}</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${new Date(item.timestamp).toLocaleString('vi-VN')}</td>
                            <td style="border: 1px solid #ddd; padding: 8px; font-family: monospace;">${item.qa_code}</td>
                            <td style="border: 1px solid #ddd; padding: 8px; font-weight: bold;">${item.username}</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${item.action_type}</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">${item.note || ''}</td>
                        </tr>
                    `;
                });

                html += `</tbody></table>`;
                tempContainer.innerHTML = html;

                // Cấu hình html2pdf
                const opt = {
                    margin:       10,
                    filename:     `Lich_Su_Thiet_Bi_${new Date().toISOString().split('T')[0]}.pdf`,
                    image:        { type: 'jpeg', quality: 0.98 },
                    html2canvas:  { scale: 2 },
                    jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };
                
                // Đổi trạng thái button UI
                const btn = document.getElementById('btnExportPdf');
                const oldText = btn.innerHTML;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xuất...';
                btn.disabled = true;

                // Xuất file từ element HTML ảo (không hiển thị lên màn hình thực)
                html2pdf().set(opt).from(tempContainer).save().then(() => {
                    btn.innerHTML = oldText;
                    btn.disabled = false;
                });

            }).catch(err => { console.error(err); alert('Lỗi trong quá trình trích xuất PDF!'); });
        }

        function addAsset() { const data = { qa_code: document.getElementById('newQa').value, name: document.getElementById('newName').value, type: document.getElementById('newType').value, room: document.getElementById('newRoom').value, status: 'Sẵn sàng' }; fetch('/api/assets', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()).then(res => { if(res.success) { document.getElementById('addModal').classList.add('hidden'); loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.error); }); }
        function openEdit(qa_code) { const item = allAssets.find(a => a.qa_code === qa_code); if(item) { document.getElementById('editQa').value = item.qa_code; document.getElementById('editName').value = item.name; document.getElementById('editType').value = item.type; document.getElementById('editRoom').value = item.room; document.getElementById('editStatus').value = item.status; document.getElementById('editModal').classList.remove('hidden'); } }
        function saveEdit() { const qa_code = document.getElementById('editQa').value; const data = { name: document.getElementById('editName').value, type: document.getElementById('editType').value, room: document.getElementById('editRoom').value, status: document.getElementById('editStatus').value }; fetch(`/api/assets/${qa_code}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()).then(res => { if(res.success) { document.getElementById('editModal').classList.add('hidden'); loadAssets(); if(currentUser.role === 'admin') loadDashboard(); } else alert('Lỗi: ' + res.error); }); }
        function deleteAsset(qa_code) { if(confirm(`Xác nhận xóa thiết bị?`)) fetch(`/api/assets/${qa_code}`, { method: 'DELETE' }).then(r => r.json()).then(res => { if(res.success) { loadAssets(); if(currentUser.role === 'admin') loadDashboard(); }}); }
        function addUser() { const data = { username: document.getElementById('newUsername').value, password: document.getElementById('newPassword').value, role: document.getElementById('newRole').value, department: document.getElementById('newDepartment').value, requester_id: currentUser.id, requester_role: currentUser.role }; if(!data.username || !data.password) return alert("Vui lòng nhập đủ thông tin!"); fetch('/api/users', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()).then(res => { if(res.success) { document.getElementById('addUserModal').classList.add('hidden'); loadUsers(); } else alert("Lỗi: " + res.error); }); }
        function deleteUser(id) { if(confirm("Xác nhận xóa tài khoản?")) { fetch('/api/users/' + id, { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ requester_id: currentUser.id, requester_role: currentUser.role }) }).then(r => r.json()).then(data => { if(data.success) loadUsers(); else alert("Lỗi: " + data.error); }); } }

        function openEditUser(id, username, role, dept) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editUserUsername').value = username;
            document.getElementById('editUserRole').value = role;
            document.getElementById('editUserDepartment').value = dept === 'null' ? '' : dept;
            document.getElementById('editUserDeptContainer').style.display = role === 'admin' ? 'none' : 'block';
            document.getElementById('editUserModal').classList.remove('hidden');
        }

        function saveEditUser() {
            const id = document.getElementById('editUserId').value;
            const data = {
                role: document.getElementById('editUserRole').value,
                department: document.getElementById('editUserDepartment').value,
                requester_role: currentUser.role
            };
            fetch('/api/users/' + id, { 
                method: 'PUT', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(data) 
            }).then(r => r.json()).then(res => { 
                if(res.success) { 
                    document.getElementById('editUserModal').classList.add('hidden'); 
                    
                    if (id == currentUser.id) {
                        currentUser.role = data.role;
                        currentUser.department = data.department;
                        localStorage.setItem('currentUser', JSON.stringify(currentUser));
                        window.location.reload(); 
                    } else {
                        loadUsers(); 
                    }
                } else alert("Lỗi: " + res.error); 
            });
        }

        function setupNotifications() {
            if (checkNotificationInterval) clearInterval(checkNotificationInterval);
            checkNotificationInterval = setInterval(() => {
                if(!allAssets || allAssets.length === 0) return; const now = new Date().getTime();
                allAssets.forEach(item => {
                    if(item.status === 'Đang sử dụng' && item.current_borrower === currentUser.username && item.expected_return) {
                        const diffMins = (new Date(item.expected_return).getTime() - now) / (1000 * 60);
                        if (diffMins > 0 && diffMins <= 15 && !notifiedAssets.has(item.qa_code)) { alert(`⏳ Cảnh báo: Thiết bị "${item.name}" sắp đến hạn trả!`); notifiedAssets.add(item.qa_code); }
                    }
                });
            }, 60000); 
        }

        function updateNotificationsUI() {
            const notifList = document.getElementById('notifList'); const notifBadge = document.getElementById('notifBadge');
            let notifications = []; const now = new Date().getTime();
            allAssets.forEach(item => {
                if(item.status === 'Đang sử dụng' && item.current_borrower === currentUser.username && item.expected_return) {
                    const diffMins = (new Date(item.expected_return).getTime() - now) / (1000 * 60);
                    if (diffMins < 0) notifications.push(`<div class="p-2 bg-red-50 rounded text-xs border border-red-100"><i class="fa-solid fa-triangle-exclamation text-red-500 mr-1"></i> <b>${item.qa_code}</b> đã quá hạn trả!</div>`);
                    else if (diffMins <= 15) notifications.push(`<div class="p-2 bg-orange-50 rounded text-xs border border-orange-100"><i class="fa-solid fa-clock text-orange-500 mr-1"></i> <b>${item.qa_code}</b> sắp đến hạn trả.</div>`);
                }
                if(item.status === 'Chờ duyệt' && (currentUser.role === 'admin' || currentUser.role === 'manager')) { notifications.push(`<div class="p-2 bg-blue-50 rounded text-xs border border-blue-100"><i class="fa-solid fa-clipboard-user text-blue-500 mr-1"></i> <b>${item.qa_code}</b> có yêu cầu cần duyệt.</div>`); }
                if(item.status === 'Hỏng' || item.status === 'Bảo trì') {
                    if (currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'tech') { notifications.push(`<div onclick="openChat('${item.qa_code}', 'general')" class="p-2 bg-red-50 cursor-pointer rounded text-xs border border-red-100 hover:bg-red-100"><i class="fa-solid fa-wrench text-red-500 mr-1"></i> Thiết bị <b>${item.qa_code}</b> đang báo lỗi!</div>`); } 
                    else if (item.current_borrower === currentUser.username) { notifications.push(`<div onclick="openChat('${item.qa_code}', 'general')" class="p-2 bg-red-50 cursor-pointer rounded text-xs border border-red-100 hover:bg-red-100"><i class="fa-solid fa-wrench text-red-500 mr-1"></i> Thiết bị <b>${item.qa_code}</b> bạn mượn bị báo lỗi!</div>`); }
                }
            });
            if (notifications.length > 0) { notifBadge.innerText = notifications.length; notifBadge.classList.remove('hidden'); notifList.innerHTML = notifications.join(''); } 
            else { notifBadge.classList.add('hidden'); notifList.innerHTML = '<div class="p-4 text-center text-gray-400 text-xs">Không có thông báo mới.</div>'; }
        }
    </script>
</body>
</html>