<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>FPT Poly Đà Nẵng - Hệ thống Quản lý Thiết bị</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>

    <style>
        :root { --fpt-orange: #F26F21; }
        .bg-fpt { background-color: var(--fpt-orange); }
        .text-fpt { color: var(--fpt-orange); }
        .border-fpt { border-color: var(--fpt-orange); }
        .active-nav { background-color: #fff3ec; color: var(--fpt-orange); border-right: 4px solid var(--fpt-orange); }
        .active-nav-mobile { color: var(--fpt-orange); }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        
        .chat-bubble { max-width: 80%; padding: 10px 14px; border-radius: 16px; margin-bottom: 8px; font-size: 14px;}
        .chat-mine { background-color: var(--fpt-orange); color: white; margin-left: auto; border-bottom-right-radius: 4px;}
        .chat-other { background-color: #f1f5f9; color: #334155; margin-right: auto; border-bottom-left-radius: 4px;}
    </style>
</head>
<body class="bg-orange-50/30 h-screen flex flex-col overflow-hidden text-gray-800 font-sans">

    <header class="bg-white shadow-sm border-b-2 border-fpt p-4 flex justify-between items-center z-40 relative">
        <div class="flex items-center gap-3">
            <div class="bg-fpt text-white font-bold px-3 py-1.5 rounded text-lg md:text-xl shadow-sm">FPT Polytechnic</div>
            <span class="font-bold text-gray-700 hidden md:inline-block text-lg border-l-2 border-orange-200 pl-3">Hệ thống Quản lý Thiết bị</span>
        </div>
        
        <div class="flex items-center gap-4">
            <div class="relative">
                <button onclick="toggleNotif()" class="text-gray-500 hover:text-fpt relative p-2 transition" title="Thông báo">
                    <i class="fa-solid fa-bell text-2xl"></i>
                    <span id="notifBadge" class="absolute top-0 right-0 bg-red-500 text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center font-bold hidden border-2 border-white shadow-sm">0</span>
                </button>
                <div id="notifDropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl shadow-2xl border border-orange-100 z-50 flex flex-col overflow-hidden">
                    <div class="p-3 border-b border-orange-50 bg-orange-50/50 font-bold text-gray-700 flex justify-between items-center">
                        <span>Thông báo</span>
                        <button onclick="toggleNotif()" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div id="notifList" class="overflow-y-auto max-h-80 p-2 flex flex-col gap-1"></div>
                </div>
            </div>

            <div class="hidden md:flex items-center gap-3 border-l border-orange-100 pl-4">
                <div class="text-right">
                    <p id="userNameDisplay" class="font-bold text-sm text-gray-800"></p>
                    <p id="userRoleDisplay" class="text-xs text-orange-600 font-medium uppercase"></p>
                </div>
                <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-fpt font-bold border border-orange-200">
                    <i class="fa-solid fa-user"></i>
                </div>
            </div>
            <button onclick="logout()" class="text-gray-500 hover:text-red-500 bg-orange-50 p-2 rounded-lg transition border border-orange-100" title="Đăng xuất"><i class="fa-solid fa-right-from-bracket text-xl"></i></button>
        </div>
    </header>

    <div class="flex-1 flex overflow-hidden relative">
        <aside class="w-64 bg-white shadow-[4px_0_24px_rgba(0,0,0,0.02)] hidden md:flex flex-col z-20 border-r border-orange-100">
            <nav class="flex-1 mt-6 flex flex-col gap-2 px-4">
                <button onclick="showTab('tabWorkspace', this)" class="nav-btn active-nav flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-gray-600 hover:bg-orange-50 transition font-medium"><i class="fa-solid fa-layer-group text-lg w-6 text-center"></i> Quản lý & Sử dụng</button>
                
                <button id="btnAdminMaintDesk" onclick="showTab('tabMaintenance', this)" class="nav-btn hidden flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-gray-600 hover:bg-orange-50 transition font-medium"><i class="fa-solid fa-screwdriver-wrench text-lg w-6 text-center"></i> Bảo trì & Sự cố</button>
                
                <button id="btnAdminDashDesk" onclick="showTab('tabDash', this)" class="nav-btn hidden flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-gray-600 hover:bg-orange-50 transition font-medium"><i class="fa-solid fa-chart-pie text-lg w-6 text-center"></i> Thống kê</button>
                <button id="btnAdminUsersDesk" onclick="showTab('tabUsers', this)" class="nav-btn hidden flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-gray-600 hover:bg-orange-50 transition font-medium"><i class="fa-solid fa-users text-lg w-6 text-center"></i> Quản lý User</button>
            </nav>
        </aside>

        <main class="flex-1 overflow-y-auto p-4 md:p-8 pb-24 md:pb-8 bg-orange-50/40 relative">
            
            <div id="tabWorkspace" class="tab-content animate-fade-in max-w-6xl mx-auto">
                <h2 class="text-2xl font-bold mb-6 text-gray-800">Không gian làm việc</h2>
                
                <div class="bg-white rounded-2xl shadow-sm border border-orange-100 p-6 mb-6 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-fpt"></div>
                    <h3 class="text-lg font-bold text-gray-800 mb-4 pl-2">Tìm kiếm & Phân loại</h3>
                    <div class="flex flex-col md:flex-row gap-2 mb-2">
                        <select id="assetCategoryFilter" onchange="filterAssets()" class="w-full md:w-1/4 p-3 bg-orange-50/50 border border-orange-200 rounded-lg focus:ring-2 focus:ring-orange-400 focus:bg-white outline-none transition font-medium text-gray-700">
                            <option value="all">Tất cả danh mục</option>
                        </select>
                        <div class="relative flex-1">
                            <i class="fa-solid fa-search absolute left-3 top-3.5 text-orange-400"></i>
                            <input type="text" id="scanCode" oninput="filterAssets()" class="w-full pl-10 p-3 bg-orange-50/50 border border-orange-200 rounded-lg focus:ring-2 focus:ring-orange-400 focus:bg-white outline-none transition" placeholder="Nhập mã QA hoặc tên thiết bị...">
                        </div>
                        <button onclick="startScanner()" class="bg-fpt text-white px-5 py-3 rounded-lg hover:bg-orange-600 shadow-md transition w-full md:w-auto font-medium"><i class="fa-solid fa-camera mr-1"></i> Quét mã QR</button>
                        <input type="file" id="qrInputFile" accept="image/*" class="hidden" onchange="scanImage(event)">
                        <button onclick="document.getElementById('qrInputFile').click()" class="bg-orange-100 text-orange-600 border border-orange-200 px-5 py-3 rounded-lg hover:bg-orange-200 transition w-full md:w-auto font-medium"><i class="fa-solid fa-image mr-1"></i> Tải ảnh QR</button>
                    </div>
                    <div id="reader" class="w-full hidden rounded-xl overflow-hidden shadow-inner border max-w-md mx-auto mt-4"></div>
                </div>

                <div class="md:bg-white md:rounded-2xl md:shadow-sm md:border border-orange-100 overflow-hidden">
                    <div class="p-4 border-b border-orange-100 hidden md:flex justify-between items-center bg-orange-50/50">
                        <h3 class="text-lg font-bold text-gray-800">Danh sách Thiết bị</h3>
                        <button id="btnAddAsset" onclick="document.getElementById('addModal').classList.remove('hidden')" class="hidden bg-fpt text-white px-4 py-2 rounded-lg shadow-md hover:bg-orange-600 transition text-sm font-medium"><i class="fa-solid fa-plus"></i> Thêm mới</button>
                    </div>
                    <div class="md:hidden flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold text-gray-800">Danh sách Thiết bị</h3>
                        <button id="btnAddAssetMob" onclick="document.getElementById('addModal').classList.remove('hidden')" class="hidden bg-fpt text-white px-4 py-1.5 rounded-lg shadow-md hover:bg-orange-600 transition text-sm font-medium"><i class="fa-solid fa-plus"></i> Thêm mới</button>
                    </div>
                    <div class="overflow-visible md:overflow-x-auto">
                        <table class="w-full text-left block md:table border-collapse">
                            <thead class="hidden md:table-header-group bg-orange-50/50 text-orange-800 text-sm uppercase">
                                <tr>
                                    <th class="p-4 border-b border-orange-100">Mã QA</th>
                                    <th class="p-4 border-b border-orange-100">Tên thiết bị</th>
                                    <th class="p-4 border-b border-orange-100">Loại / Phòng</th>
                                    <th class="p-4 border-b border-orange-100">Trạng thái & Người mượn</th>
                                    <th class="p-4 border-b border-orange-100 text-center w-64">Thao tác</th>
                                    <th class="p-4 border-b border-orange-100 text-center w-32">Quản lý</th>
                                </tr>
                            </thead>
                            <tbody id="assetTableBody" class="block md:table-row-group text-gray-700 text-sm"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tab Bảo trì -->
            <div id="tabMaintenance" class="tab-content hidden animate-fade-in max-w-6xl mx-auto">
                <div class="flex items-center gap-3 mb-6">
                    <i class="fa-solid fa-screwdriver-wrench text-3xl text-emerald-500"></i>
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Quản lý yêu cầu bảo trì</h2>
                        <p class="text-sm text-gray-500">Tiếp nhận và xử lý các thông báo hỏng hóc từ nhân viên.</p>
                    </div>
                </div>
                <div class="bg-white rounded-2xl shadow-sm border border-emerald-100 overflow-hidden">
                    <div class="overflow-x-auto p-4">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-emerald-50/50 text-emerald-800 text-sm uppercase rounded-lg border-b border-emerald-100">
                                <tr>
                                    <th class="p-4 font-semibold">Thiết bị lỗi</th>
                                    <th class="p-4 font-semibold">Người báo cáo</th>
                                    <th class="p-4 font-semibold">Mô tả lỗi</th>
                                    <th class="p-4 font-semibold">Trạng thái</th>
                                    <th class="p-4 font-semibold text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="maintenanceTableBody" class="text-gray-700 text-sm divide-y divide-emerald-50"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Dashboard -->
            <div id="tabDash" class="tab-content hidden animate-fade-in max-w-6xl mx-auto">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-800">Thống kê & Phân tích</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-orange-100 md:col-span-1 flex flex-col justify-center items-center">
                        <h3 class="text-md font-bold text-gray-700 mb-2 w-full text-left">Tỷ lệ Trạng thái</h3>
                        <div class="w-full h-48 relative"><canvas id="statusChart"></canvas></div>
                    </div>
                    <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-3 gap-6">
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-blue-100 flex items-center gap-4"><div class="w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-2xl z-10"><i class="fa-solid fa-server"></i></div><div class="z-10"><p class="text-sm text-gray-500 font-medium mb-1">Tổng thiết bị</p><h3 class="text-3xl font-bold" id="dashTotal">0</h3></div></div>
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-emerald-100 flex items-center gap-4"><div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center text-2xl z-10"><i class="fa-solid fa-circle-check"></i></div><div class="z-10"><p class="text-sm text-gray-500 font-medium mb-1">Đang sử dụng</p><h3 class="text-3xl font-bold" id="dashInUse">0</h3></div></div>
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-red-100 flex items-center gap-4"><div class="w-14 h-14 rounded-full bg-red-50 text-red-500 flex items-center justify-center text-2xl z-10"><i class="fa-solid fa-wrench"></i></div><div class="z-10"><p class="text-sm text-gray-500 font-medium mb-1">Hỏng / Bảo trì</p><h3 class="text-3xl font-bold" id="dashBroken">0</h3></div></div>
                    </div>
                </div>

                <!-- TOP SỬ DỤNG VÀ THIẾT BỊ -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-orange-100">
                        <h3 class="text-md font-bold text-gray-700 mb-4 border-l-4 border-yellow-500 pl-2"><i class="fa-solid fa-laptop text-yellow-500 mr-1"></i> Thiết Bị Được Mượn Nhiều Nhất</h3>
                        <div id="topAssetsList" class="space-y-3">
                            <div class="text-center text-gray-400 text-sm py-4 italic"><i class="fa-solid fa-spinner fa-spin mr-1"></i> Đang tải dữ liệu...</div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-orange-100">
                        <h3 class="text-md font-bold text-gray-700 mb-4 border-l-4 border-blue-500 pl-2"><i class="fa-solid fa-user-check text-blue-500 mr-1"></i> Top Người Dùng Tích Cực</h3>
                        <div id="topUsersList" class="space-y-3">
                            <div class="text-center text-gray-400 text-sm py-4 italic"><i class="fa-solid fa-spinner fa-spin mr-1"></i> Đang tải dữ liệu...</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-orange-100 flex flex-col md:flex-row justify-between items-center gap-6">
                    <div class="text-center md:text-left">
                        <h3 class="text-lg font-bold text-gray-800 mb-1">Báo cáo Trạng thái & Lịch sử</h3>
                        <p class="text-sm text-gray-500">Trích xuất dữ liệu vận hành và lịch sử mượn/trả trong 30 ngày qua.</p>
                    </div>
                    <div class="flex flex-col md:flex-row gap-3">
                        <button onclick="exportHistoryExcel()" class="bg-emerald-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-emerald-600 shadow-md transition"><i class="fa-solid fa-file-excel"></i> Xuất Excel (30 Ngày)</button>
                        <button onclick="exportPDF()" class="bg-red-500 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-red-600 shadow-md transition" id="btnExportPdf"><i class="fa-solid fa-file-pdf"></i> Xuất PDF Lịch Sử</button>
                    </div>
                </div>
            </div>

            <!-- Users Tab -->
            <div id="tabUsers" class="tab-content hidden animate-fade-in max-w-6xl mx-auto">
                <h2 class="text-2xl font-bold mb-6 text-gray-800">Quản lý User</h2>
                <div class="bg-white rounded-2xl shadow-sm border border-orange-100 overflow-hidden">
                    <div class="p-4 border-b flex justify-between items-center bg-orange-50/50"><h3 class="text-lg font-bold">Danh sách Tài khoản</h3><button onclick="document.getElementById('addUserModal').classList.remove('hidden')" class="bg-fpt text-white px-4 py-2 rounded-lg text-sm font-medium"><i class="fa-solid fa-user-plus"></i> Thêm User mới</button></div>
                    <div class="overflow-x-auto p-4"><table class="w-full text-left border-collapse"><thead class="bg-orange-50/50 text-orange-800 text-sm uppercase rounded-lg"><tr><th class="p-4 border-b border-orange-100">ID</th><th class="p-4 border-b border-orange-100">Tài khoản</th><th class="p-4 border-b border-orange-100">Phân quyền</th><th class="p-4 border-b border-orange-100">Phòng ban</th><th class="p-4 border-b border-orange-100 text-center">Thao tác</th></tr></thead><tbody id="userTableBody" class="text-gray-700 text-sm divide-y divide-orange-50"></tbody></table></div>
                </div>
            </div>
        </main>
        
        <nav class="md:hidden fixed bottom-0 w-full bg-white border-t border-orange-100 flex justify-around p-2 z-40 shadow-[0_-5px_15px_-5px_rgba(242,111,33,0.1)]" id="mobileNav">
            <button onclick="showTab('tabWorkspace', this, true)" class="nav-btn-mob active-nav-mobile flex flex-col items-center p-2 w-full"><i class="fa-solid fa-layer-group text-xl mb-1"></i><span class="text-[10px]">Quản lý</span></button>
            <button id="btnAdminMaintMob" onclick="showTab('tabMaintenance', this, true)" class="nav-btn-mob hidden flex flex-col items-center p-2 text-gray-400 w-full"><i class="fa-solid fa-screwdriver-wrench text-xl mb-1"></i><span class="text-[10px]">Bảo trì</span></button>
            <button id="btnAdminDashMob" onclick="showTab('tabDash', this, true)" class="nav-btn-mob hidden flex flex-col items-center p-2 text-gray-400 w-full"><i class="fa-solid fa-chart-pie text-xl mb-1"></i><span class="text-[10px]">Thống kê</span></button>
            <button id="btnAdminUsersMob" onclick="showTab('tabUsers', this, true)" class="nav-btn-mob hidden flex flex-col items-center p-2 text-gray-400 w-full"><i class="fa-solid fa-users text-xl mb-1"></i><span class="text-[10px]">Users</span></button>
        </nav>
    </div>

    <!-- Modal Repair Chat -->
    <div id="repairChatModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-lg relative shadow-2xl border flex flex-col h-[70vh]">
            <div id="chatModalHeader" class="p-4 border-b flex justify-between items-center rounded-t-3xl transition-colors">
                <h3 class="text-lg font-bold text-gray-800"><i id="chatIcon" class="mr-2"></i> <span id="chatAssetCode" class="font-mono"></span></h3>
                <button onclick="closeChat()" class="text-gray-400 hover:text-gray-800"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>
            <div id="repairChatBox" class="flex-1 p-4 overflow-y-auto flex flex-col gap-3 bg-gray-50"></div>
            <div class="p-4 border-t bg-white rounded-b-3xl flex gap-2">
                <input type="text" id="repairChatInput" class="flex-1 p-3 bg-gray-50 border border-gray-200 rounded-xl outline-none" placeholder="...">
                <button id="btnSendChat" onclick="sendRepairMessage()" class="px-5 py-3 rounded-xl font-bold transition"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
        </div>
    </div>

    <div id="detailModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div class="bg-white p-6 md:p-8 rounded-3xl shadow-2xl w-full max-w-2xl relative">
            <button onclick="document.getElementById('detailModal').classList.add('hidden')" class="absolute top-4 right-4 text-orange-300 hover:text-orange-600 bg-orange-50 rounded-full w-8 h-8 flex items-center justify-center"><i class="fa-solid fa-xmark"></i></button>
            <h3 class="text-xl font-bold mb-6 border-l-4 border-fpt pl-3">Chi tiết Thiết bị</h3>
            <div class="flex flex-col md:flex-row gap-6">
                <div class="flex-1 space-y-3 text-sm">
                    <p><span class="font-semibold text-gray-500 w-24 inline-block">Mã QA:</span> <span id="detQa" class="font-mono font-bold bg-gray-100 px-2 py-0.5 rounded"></span></p>
                    <p><span class="font-semibold text-gray-500 w-24 inline-block">Tên thiết bị:</span> <span id="detName" class="font-medium"></span></p>
                    <p><span class="font-semibold text-gray-500 w-24 inline-block">Loại/Phòng:</span> <span id="detTypeRoom"></span></p>
                    <p><span class="font-semibold text-gray-500 w-24 inline-block">Trạng thái:</span> <span id="detStatus"></span></p>
                    <div class="bg-orange-50/50 p-3 rounded-lg border border-orange-100 mt-2"><span class="font-semibold text-orange-600 block mb-1"><i class="fa-solid fa-note-sticky"></i> Ghi chú:</span><span id="detNote" class="text-gray-700 italic"></span></div>
                </div>
                <div class="flex flex-col items-center justify-center md:border-l border-gray-100 md:pl-6">
                    <div id="detQRCode" class="p-3 bg-white border border-gray-200 rounded-xl mb-4"></div>
                    <div class="flex gap-2 w-full max-w-[200px]">
                        <button onclick="downloadQR()" class="flex-1 bg-orange-50 text-orange-600 py-2 rounded-lg text-xs font-bold hover:bg-orange-100"><i class="fa-solid fa-download"></i> Tải về</button>
                        <button onclick="printQR()" class="flex-1 bg-blue-50 text-blue-600 py-2 rounded-lg text-xs font-bold hover:bg-blue-100"><i class="fa-solid fa-print"></i> In mã</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="actionModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4"><div class="bg-white rounded-3xl p-6 w-full max-w-sm relative"><button onclick="document.getElementById('actionModal').classList.add('hidden')" class="absolute top-4 right-4 text-orange-300"><i class="fa-solid fa-xmark"></i></button><h3 class="text-xl font-bold mb-2" id="actionModalTitle">Xác nhận</h3><p class="text-sm text-gray-500 mb-4" id="actionModalDesc"></p><input type="hidden" id="actionQaCode"><input type="hidden" id="actionType"><div class="space-y-4"><input type="text" id="actionNewRoom" class="hidden w-full p-3 bg-orange-50/50 rounded-xl outline-none" placeholder="Phòng chuyển đến"><div id="expectedReturnContainer" class="hidden flex flex-col gap-1"><label class="text-sm font-semibold pl-1">Dự kiến trả</label><input type="datetime-local" id="actionExpectedReturn" class="w-full p-3 bg-orange-50/50 rounded-xl outline-none"></div><textarea id="actionNote" rows="3" class="w-full p-3 bg-orange-50/50 rounded-xl outline-none" placeholder="Nhập ghi chú..."></textarea><button onclick="submitAction()" id="btnSubmitAction" class="w-full bg-fpt text-white p-3 rounded-xl font-bold">Xác nhận</button></div></div></div>
    
    <div id="addModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4"><div class="bg-white rounded-3xl p-8 w-full max-w-lg relative"><button onclick="document.getElementById('addModal').classList.add('hidden')" class="absolute top-4 right-4"><i class="fa-solid fa-xmark"></i></button><h3 class="text-xl font-bold mb-6 border-l-4 border-fpt pl-3">Thêm mới thiết bị</h3><div class="space-y-4"><input type="text" id="newQa" placeholder="Mã QA" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><input type="text" id="newName" placeholder="Tên thiết bị" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><div class="grid grid-cols-2 gap-4"><input type="text" id="newType" placeholder="Loại" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><input type="text" id="newRoom" placeholder="Phòng" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"></div><button onclick="addAsset()" class="w-full bg-fpt text-white p-3.5 rounded-xl font-bold">Thêm thiết bị</button></div></div></div>
    
    <div id="editModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4"><div class="bg-white rounded-3xl p-8 w-full max-w-lg relative"><button onclick="document.getElementById('editModal').classList.add('hidden')" class="absolute top-4 right-4"><i class="fa-solid fa-xmark"></i></button><h3 class="text-xl font-bold mb-6 border-l-4 border-fpt pl-3">Chỉnh sửa thiết bị</h3><div class="space-y-4"><input type="text" id="editQa" disabled class="w-full p-3.5 bg-gray-100 rounded-xl font-mono"><input type="text" id="editName" placeholder="Tên thiết bị" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><div class="grid grid-cols-2 gap-4"><input type="text" id="editType" placeholder="Loại" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><input type="text" id="editRoom" placeholder="Phòng" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"></div><select id="editStatus" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><option value="Sẵn sàng">Sẵn sàng</option><option value="Đang sử dụng">Đang sử dụng</option><option value="Hỏng">Hỏng</option><option value="Bảo trì">Bảo trì</option></select><button onclick="saveEdit()" class="w-full bg-blue-500 text-white p-3.5 rounded-xl font-bold">Lưu thay đổi</button></div></div></div>
    
    <div id="addUserModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4"><div class="bg-white rounded-3xl p-8 w-full max-w-sm relative"><button onclick="document.getElementById('addUserModal').classList.add('hidden')" class="absolute top-4 right-4 text-orange-300"><i class="fa-solid fa-xmark"></i></button><h3 class="text-xl font-bold mb-6 border-l-4 border-fpt pl-3">Thêm User mới</h3><div class="space-y-4"><input type="text" id="newUsername" placeholder="Tên đăng nhập" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><input type="password" id="newPassword" placeholder="Mật khẩu" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><select id="newRole" onchange="document.getElementById('deptContainer').style.display = this.value === 'admin' ? 'none' : 'block'" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><option value="staff">Nhân viên</option><option id="optManager" value="manager">Tổ trưởng</option><option id="optAdmin" value="admin">Quản trị viên</option><option value="tech">Kỹ thuật viên (IT)</option></select><div id="deptContainer"><input type="text" id="newDepartment" placeholder="Phòng ban" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"></div><button onclick="addUser()" class="w-full bg-fpt text-white p-3.5 rounded-xl font-bold">Tạo User</button></div></div></div>

    <div id="editUserModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4"><div class="bg-white rounded-3xl p-8 w-full max-w-sm relative"><button onclick="document.getElementById('editUserModal').classList.add('hidden')" class="absolute top-4 right-4 text-orange-300"><i class="fa-solid fa-xmark"></i></button><h3 class="text-xl font-bold mb-6 border-l-4 border-fpt pl-3">Cập nhật Quyền User</h3><div class="space-y-4"><input type="hidden" id="editUserId"><input type="text" id="editUserUsername" disabled class="w-full p-3.5 bg-gray-100 rounded-xl font-mono text-gray-500"><select id="editUserRole" onchange="document.getElementById('editUserDeptContainer').style.display = this.value === 'admin' ? 'none' : 'block'" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"><option value="staff">Nhân viên</option><option value="manager">Tổ trưởng</option><option value="admin">Quản trị viên</option><option value="tech">Kỹ thuật viên (IT)</option></select><div id="editUserDeptContainer"><input type="text" id="editUserDepartment" placeholder="Phòng ban" class="w-full p-3.5 bg-orange-50/50 rounded-xl outline-none"></div><button onclick="saveEditUser()" class="w-full bg-blue-500 text-white p-3.5 rounded-xl font-bold">Lưu thay đổi</button></div></div></div>

    <!-- MAIN SCRIPT -->
    <script>
        let currentUser = JSON.parse(localStorage.getItem('currentUser'));
        let html5QrcodeScanner = null;
        let allAssets = [];
        let historyData = [];
        let statusChartInstance = null;
        let checkNotificationInterval = null;
        let notifiedAssets = new Set();
        
        let currentChatQaCode = null;
        let currentChatType = 'general'; 
        const socket = io(); 

        if (!currentUser) { 
            window.location.href = '/login'; 
        } else {
            document.getElementById('userNameDisplay').innerText = currentUser.username;
            let roleName = "Nhân viên"; 
            if(currentUser.role === 'admin') roleName = "Quản trị viên"; 
            if(currentUser.role === 'manager') roleName = "Tổ trưởng";
            if(currentUser.role === 'tech') roleName = "Kỹ thuật viên";
            document.getElementById('userRoleDisplay').innerText = roleName;
            
            if(currentUser.role === 'admin') { 
                document.getElementById('btnAdminDashDesk').classList.remove('hidden'); 
                document.getElementById('btnAdminDashMob').classList.remove('hidden'); 
                loadDashboard(); 
            }
            if(currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'tech') {
                document.getElementById('btnAdminMaintDesk').classList.remove('hidden'); 
                document.getElementById('btnAdminMaintMob').classList.remove('hidden');
                
                if (currentUser.role !== 'tech') {
                    document.getElementById('btnAdminUsersDesk').classList.remove('hidden'); 
                    document.getElementById('btnAdminUsersMob').classList.remove('hidden');
                    document.getElementById('btnAddAsset').classList.remove('hidden'); 
                    document.getElementById('btnAddAssetMob').classList.remove('hidden');
                    if(currentUser.role === 'manager') { 
                        document.getElementById('optManager').classList.add('hidden'); 
                        document.getElementById('optAdmin').classList.add('hidden'); 
                    }
                    loadUsers();
                }
            }

            const savedTab = localStorage.getItem('currentTab') || 'tabWorkspace';
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            const activeTabEl = document.getElementById(savedTab);
            if(activeTabEl) activeTabEl.classList.remove('hidden');
            
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.remove('active-nav');
                b.style.borderRight = 'none';
                if(b.getAttribute('onclick') && b.getAttribute('onclick').includes(savedTab)) {
                    b.classList.add('active-nav');
                }
            });

            document.querySelectorAll('.nav-btn-mob').forEach(b => {
                b.classList.remove('active-nav-mobile'); 
                b.classList.add('text-gray-400');
                if(b.getAttribute('onclick') && b.getAttribute('onclick').includes(savedTab)) {
                    b.classList.add('active-nav-mobile'); 
                    b.classList.remove('text-gray-400');
                }
            });

            loadAssets();
            setupNotifications();
            
            document.getElementById('repairChatInput').addEventListener('keypress', function(e) {
                if(e.key === 'Enter') sendRepairMessage();
            });
        }

        function showTab(tabId, element, isMobile = false) { 
            localStorage.setItem('currentTab', tabId);
            
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden')); 
            document.getElementById(tabId).classList.remove('hidden'); 
            
            if(isMobile) { 
                document.querySelectorAll('.nav-btn-mob').forEach(b => { b.classList.remove('active-nav-mobile'); b.classList.add('text-gray-400'); }); 
                element.classList.add('active-nav-mobile'); element.classList.remove('text-gray-400'); 
            } else { 
                document.querySelectorAll('.nav-btn').forEach(b => { b.classList.remove('active-nav'); b.style.borderRight = 'none'; }); 
                element.classList.add('active-nav'); 
            } 
        }

        function openChat(qa_code, chatType = 'general') {
            currentChatQaCode = qa_code;
            currentChatType = chatType;
            let displayTitle = chatType === 'tech' ? `Kênh Nội Bộ (Admin & IT): ${qa_code}` : `Ticket Sự cố chung: ${qa_code}`;
            document.getElementById('chatAssetCode').innerText = displayTitle;

            const headerEl = document.getElementById('chatModalHeader');
            const iconEl = document.getElementById('chatIcon');
            const codeEl = document.getElementById('chatAssetCode');
            const sendBtn = document.getElementById('btnSendChat');
            
            if (chatType === 'tech') {
                headerEl.className = "p-4 border-b border-purple-200 flex justify-between items-center bg-purple-50 rounded-t-3xl transition-colors";
                iconEl.className = "fa-solid fa-user-shield text-purple-600 mr-2";
                codeEl.className = "text-purple-700 font-mono";
                sendBtn.className = "bg-purple-600 text-white px-5 py-3 rounded-xl font-bold hover:bg-purple-700 transition";
            } else {
                headerEl.className = "p-4 border-b border-blue-200 flex justify-between items-center bg-blue-50 rounded-t-3xl transition-colors";
                iconEl.className = "fa-solid fa-ticket text-blue-600 mr-2";
                codeEl.className = "text-blue-700 font-mono";
                sendBtn.className = "bg-blue-600 text-white px-5 py-3 rounded-xl font-bold hover:bg-blue-700 transition";
            }

            document.getElementById('repairChatInput').disabled = false;
            document.getElementById('repairChatInput').placeholder = chatType === 'tech' ? "Nhập tin nhắn trao đổi nội bộ..." : "Nhập nội dung trao đổi sự cố...";
            document.getElementById('repairChatModal').classList.remove('hidden');
            let roomCode = chatType === 'tech' ? qa_code + '_tech' : qa_code;
            loadRepairChat(roomCode);
        }
        
        function closeChat() { document.getElementById('repairChatModal').classList.add('hidden'); currentChatQaCode = null; }
        
        function sendRepairMessage() {
            const msgInput = document.getElementById('repairChatInput'); const message = msgInput.value.trim();
            if(!message || !currentChatQaCode) return;
            let roomCode = currentChatType === 'tech' ? currentChatQaCode + '_tech' : currentChatQaCode;
            socket.emit("sendMessage", { qa_code: roomCode, sender: currentUser.username, role: currentUser.role, message: message });
            msgInput.value = '';
        }
        
        function loadRepairChat(roomCode) {
            fetch(`/api/messages/${roomCode}`).then(r => r.json()).then(data => {
                const box = document.getElementById('repairChatBox'); if(!box) return;
                box.innerHTML = '<div class="text-center text-xs text-gray-400 my-2">Bắt đầu trao đổi...</div>';
                if(Array.isArray(data)) {
                    let startIndex = 0;
                    if (!roomCode.endsWith('_tech')) {
                        for (let i = data.length - 1; i >= 0; i--) {
                            if (data[i].role === 'system' && data[i].message.includes('đã báo hỏng thiết bị')) { startIndex = i; break; }
                        }
                    }
                    const sessionData = data.slice(startIndex);
                    sessionData.forEach(msg => appendRepairMessage(msg));
                    const lastMsg = sessionData[sessionData.length - 1];
                    if(lastMsg && lastMsg.role === 'system' && lastMsg.message.includes('sửa chữa thành công')) {
                        document.getElementById('repairChatInput').disabled = true;
                        document.getElementById('repairChatInput').placeholder = "Sự cố đã được giải quyết.";
                    }
                }
                setTimeout(() => { box.scrollTop = box.scrollHeight; }, 100);
            }).catch(e => console.log('Lỗi tải chat lỗi', e));
        }

        function appendRepairMessage(data) {
            const box = document.getElementById('repairChatBox'); if(!box) return;
            const isMine = data.sender === currentUser.username;
            const timeStr = new Date(data.timestamp || new Date()).toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit'});
            let rTag = data.role === 'admin' ? ' - Admin' : (data.role === 'manager' ? ' - Tổ trưởng' : (data.role === 'tech' ? ' - Kỹ thuật' : ''));
            if(data.role === 'system') {
                box.innerHTML += `<div class="text-center text-xs text-orange-500 font-semibold my-2 italic p-2 bg-orange-50 rounded-lg mx-auto max-w-[90%]">${data.message}</div>`;
                box.scrollTop = box.scrollHeight; return;
            }
            
            let myBgClass = currentChatType === 'tech' ? 'bg-purple-600 text-white' : 'bg-blue-600 text-white';
            let roleColorClass = currentChatType === 'tech' ? 'text-purple-500' : 'text-blue-500';

            box.innerHTML += `<div class="flex flex-col ${isMine ? 'items-end' : 'items-start'} w-full"><span class="text-[10px] text-gray-500 font-bold mb-0.5 ml-1">${data.sender} <span class="${roleColorClass}">${rTag}</span></span><div class="max-w-[80%] p-2.5 rounded-xl text-sm ${isMine ? myBgClass + ' rounded-br-none shadow' : 'bg-white border border-gray-200 text-gray-800 rounded-bl-none shadow-sm'}">${data.message}</div><span class="text-[9px] text-gray-400 mt-0.5 mx-1">${timeStr}</span></div>`;
            box.scrollTop = box.scrollHeight;
        }

        socket.on("receiveMessage", (data) => {
            if (data.qa_code === 'GLOBAL') return;
            let activeRoomCode = currentChatQaCode ? (currentChatType === 'tech' ? currentChatQaCode + '_tech' : currentChatQaCode) : null;
            if(activeRoomCode === data.qa_code) {
                appendRepairMessage(data);
                if (data.role === 'system' && data.message.includes('sửa chữa thành công')) {
                    document.getElementById('repairChatInput').disabled = true; document.getElementById('repairChatInput').value = ''; document.getElementById('repairChatInput').placeholder = "Sự cố đã được giải quyết.";
                    setTimeout(() => { closeChat(); alert('Thiết bị đã được sửa xong. Ticket hỗ trợ tự động đóng lại!'); }, 1500);
                }
            } else {
                let isTechMsg = data.qa_code.endsWith('_tech'); let baseQaCode = isTechMsg ? data.qa_code.replace('_tech', '') : data.qa_code;
                const item = allAssets.find(a => a.qa_code === baseQaCode);
                if(item && (item.status === 'Hỏng' || item.status === 'Bảo trì')) {
                    const notifList = document.getElementById('notifList'); const notifBadge = document.getElementById('notifBadge'); let added = false;
                    if (isTechMsg && (currentUser.role === 'admin' || currentUser.role === 'tech')) {
                        notifList.innerHTML = `<div onclick="openChat('${baseQaCode}', 'tech')" class="p-2 bg-purple-50 cursor-pointer rounded text-xs border border-purple-100 hover:bg-purple-100"><i class="fa-solid fa-user-gear text-purple-500 mr-1"></i> Tin nhắn Kỹ thuật từ: <b>${baseQaCode}</b></div>` + notifList.innerHTML; added = true;
                    } else if (!isTechMsg && (currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'tech' || item.current_borrower === currentUser.username)) {
                        notifList.innerHTML = `<div onclick="openChat('${baseQaCode}', 'general')" class="p-2 bg-blue-50 cursor-pointer rounded text-xs border border-blue-100 hover:bg-blue-100"><i class="fa-solid fa-comment-dots text-blue-500 mr-1"></i> Có tin nhắn mới từ Ticket chung: <b>${baseQaCode}</b></div>` + notifList.innerHTML; added = true;
                    }
                    if (added) { notifBadge.innerText = parseInt(notifBadge.innerText || 0) + 1; notifBadge.classList.remove('hidden'); }
                }
            }
        });

        function renderTable(dataToRender) {
            const tbody = document.getElementById('assetTableBody'); if(!tbody) return; tbody.innerHTML = '';
            if(dataToRender.length === 0) { tbody.innerHTML = `<tr><td colspan="6" class="p-6 text-center text-gray-500 font-medium">Không tìm thấy thiết bị nào!</td></tr>`; return; }
            dataToRender.forEach(item => {
                let displayStatus = item.status; let statusColor = "text-gray-600"; let borrowerInfo = '';
                if (item.status === 'Đang sử dụng' && item.borrow_time) {
                    const borrowDate = new Date(item.borrow_time); const timeStr = borrowDate.toLocaleString('vi-VN', { hour: '2-digit', minute:'2-digit', day: '2-digit', month: '2-digit' });
                    let expectedReturnDate = item.expected_return ? new Date(item.expected_return) : new Date(borrowDate.getTime() + 3 * 24 * 60 * 60 * 1000);
                    let timeDiff = expectedReturnDate.getTime() - new Date().getTime(); let daysOverdue = Math.floor(-timeDiff / (1000 * 60 * 60 * 24)); 
                    let noteStr = item.borrow_note ? `<br><span class="text-xs text-orange-600 font-medium mt-1 flex items-start gap-1"><i class="fa-solid fa-comment-dots mt-0.5"></i> Ghi chú: ${item.borrow_note}</span>` : '';
                    let reserveStr = item.reservations_count > 0 ? `<br><span class="text-xs text-indigo-600 font-bold mt-1 flex items-start gap-1"><i class="fa-solid fa-calendar-check mt-0.5"></i> Có ${item.reservations_count} người Đặt lịch</span>` : '';
                    borrowerInfo = `<br><span class="text-xs text-gray-500 font-normal mt-1 block"><i class="fa-solid fa-user-clock text-orange-400"></i> ${item.current_borrower} (Lúc: ${timeStr})</span>${noteStr}${reserveStr}`;
                    
                    if (timeDiff < 0 && daysOverdue >= 3) { displayStatus = `Mất (Quá hạn ${daysOverdue} ngày)`; statusColor = "text-red-600 font-bold bg-red-50 px-2 py-1 rounded-md inline-block border border-red-100"; } 
                    else if (timeDiff < 0) { displayStatus = `Quá hạn (${daysOverdue === 0 ? "hôm nay" : daysOverdue + " ngày"})`; statusColor = "text-orange-600 font-bold bg-orange-50 px-2 py-1 rounded-md inline-block border border-orange-200"; } 
                    else { displayStatus = `Đang mượn (Đến ${expectedReturnDate.toLocaleString('vi-VN', { hour: '2-digit', minute:'2-digit', day: '2-digit', month: '2-digit' })})`; statusColor = "text-blue-600 font-bold bg-blue-50 px-2 py-1 rounded-md inline-block border border-blue-100"; }
                } else if (item.status === 'Chờ duyệt') { statusColor = "text-yellow-600 font-bold bg-yellow-50 px-2 py-1 rounded-md inline-block border border-yellow-200"; displayStatus = "Đang chờ duyệt"; } 
                else if (item.status === 'Sẵn sàng') { statusColor = "text-emerald-600 font-bold bg-emerald-50 px-2 py-1 rounded-md inline-block border border-emerald-100"; } 
                else if (item.status === 'Hỏng' || item.status === 'Bảo trì') { statusColor = "text-red-600 font-bold bg-red-50 px-2 py-1 rounded-md inline-block border border-red-100"; }

                let actionHTML = '';
                if (currentUser.role !== 'tech') {
                    if (item.status === 'Sẵn sàng') { actionHTML += `<button onclick="openActionModal('${item.qa_code}', 'Mượn')" class="w-full md:w-auto bg-blue-50 text-blue-600 border border-blue-200 px-3 py-1.5 rounded-md hover:bg-blue-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap"><i class="fa-solid fa-arrow-right-to-bracket"></i> Mượn</button>`; } 
                    else if (item.status === 'Chờ duyệt') {
                        if (currentUser.role === 'admin' || currentUser.role === 'manager') {
                            actionHTML += `<button onclick="approveRequest('${item.qa_code}', 'approve')" class="w-full md:w-auto bg-emerald-50 text-emerald-600 border border-emerald-200 px-3 py-1.5 rounded-md hover:bg-emerald-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap md:mr-1 mb-1 md:mb-0"><i class="fa-solid fa-check"></i> Duyệt</button>`;
                            actionHTML += `<button onclick="approveRequest('${item.qa_code}', 'reject')" class="w-full md:w-auto bg-red-50 text-red-600 border border-red-200 px-3 py-1.5 rounded-md hover:bg-red-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap"><i class="fa-solid fa-xmark"></i> T.chối</button>`;
                        } else actionHTML += `<div class="flex flex-col gap-1 w-full"><span class="text-xs text-yellow-600 font-semibold italic flex items-center justify-center"><i class="fa-solid fa-hourglass-half mr-1"></i> Chờ duyệt</span><button onclick="openActionModal('${item.qa_code}', 'Đăng ký mượn')" class="w-full bg-purple-50 text-purple-600 border border-purple-200 px-3 py-1.5 rounded-md hover:bg-purple-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap"><i class="fa-solid fa-calendar-plus"></i> Đặt lịch trước</button></div>`;
                    } else if (item.status === 'Đang sử dụng') {
                        if (currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.username === item.current_borrower) { actionHTML += `<button onclick="openActionModal('${item.qa_code}', 'Trả')" class="w-full md:w-auto bg-emerald-50 text-emerald-600 border border-emerald-200 px-3 py-1.5 rounded-md hover:bg-emerald-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap"><i class="fa-solid fa-arrow-right-from-bracket"></i> Trả</button>`; } 
                        else actionHTML += `<button onclick="openActionModal('${item.qa_code}', 'Đăng ký mượn')" class="w-full md:w-auto bg-purple-50 text-purple-600 border border-purple-200 px-3 py-1.5 rounded-md hover:bg-purple-500 hover:text-white transition-all text-xs font-bold whitespace-nowrap mt-1"><i class="fa-solid fa-calendar-plus"></i> Đặt lịch trước</button>`;
                    }
                    if (item.status !== 'Hỏng' && item.status !== 'Bảo trì' && item.status !== 'Chờ duyệt') {
